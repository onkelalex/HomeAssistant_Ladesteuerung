blueprint:
  name: 🔋 Hausbatterie Steuerung mit Wallbox & Strompreis
  description: >
    Version 0.8

    Steuert eine Hoymiles/MS-A2 Hausbatterie bei Wallbox-Ladung,
    manuellem Sofortladen, automatischem Preisladen und preisabhängiger
    Akku-Entladung.

    Änderungen in 0.8:
    - Automatisches Preisladen bleibt über einen eigenen input_boolean-Helfer steuerbar.
    - Die Lade-Preisgrenze kommt ausschließlich aus einem input_number-Helfer in €/kWh.
    - Der Akku lädt bei günstigem Strompreis bis zum Ziel-Ladestand.
    - Der Akku entlädt nur noch, wenn der Strompreis teuer genug ist.
    - "Teuer genug" bedeutet: aktueller Strompreis >= Lade-Preisgrenze + Entlade-Preisaufschlag.
    - Der Entlade-Preisaufschlag ist als Eingabefeld im Blueprint konfigurierbar.
    - Der Mindestwert für den Entlade-Preisaufschlag ist 0,10 €/kWh.
    - Zusätzlich gibt es einen Schalter, um die Akku-Entladung komplett zu sperren.
    - Wenn Entladung nicht erlaubt ist, wird die Batterie auf mqtt_ctrl mit 0 W gesetzt.
    - Komma- und Punktwerte werden verarbeitet, z. B. 0,16 und 0.16.

    Logik:
    1. Sofortladen aktiv und SOC unter Zielwert → Akku lädt.
    2. Automatisches Preisladen aktiv, Strompreis unter Lade-Preisgrenze und SOC unter Zielwert → Akku lädt.
    3. Wallbox lädt → Akku-Entladung wird gestoppt.
    4. Entladung gesperrt → Akku bleibt neutral bei 0 W.
    5. Strompreis nicht teuer genug → Akku bleibt neutral bei 0 W.
    6. Strompreis teuer genug → Akku darf im Normalmodus entladen.

    Benötigte Helfer:
    - input_boolean für Sofortladen
    - input_boolean für automatisches Preisladen
    - input_boolean für Entladung sperren
    - input_number für Ziel-Ladestand
    - input_number für Lade-Preisgrenze in €/kWh

    Wichtig:
    Der Strompreis-Sensor und der Preisgrenzen-Helfer müssen beide in €/kWh arbeiten.
    Beispiel: 0,16 €/kWh entspricht 16 ct/kWh.
  domain: automation

  input:
    battery_mode_select:
      name: Batterie Betriebsmodus Select
      description: z. B. select.msa_280024230201_mqtt_select
      selector:
        entity:
          domain: select

    battery_power_number:
      name: Batterie Leistungs-Number
      description: z. B. number.msa_280024230201
      selector:
        entity:
          domain: number

    battery_soc_sensor:
      name: Batterie SOC Sensor
      description: z. B. sensor.msa_280024230201_state_of_charge_system
      selector:
        entity:
          domain: sensor

    wallbox_status_sensor:
      name: Wallbox Status Sensor
      description: z. B. sensor.easee_charge_up_status
      selector:
        entity:
          domain: sensor

    force_charge_switch:
      name: Sofortladen Schalter
      description: z. B. input_boolean.akku_sofort_laden
      selector:
        entity:
          domain: input_boolean

    price_charging_switch:
      name: Automatisches Preisladen Schalter
      description: z. B. input_boolean.akku_automatisches_preisladen
      selector:
        entity:
          domain: input_boolean

    discharge_block_switch:
      name: Akku-Entladung sperren Schalter
      description: >
        input_boolean-Helfer zum Sperren der Akku-Entladung.
        Wenn dieser Schalter an ist, wird die Batterie nicht entladen.
        Laden bei günstigem Strompreis oder Sofortladen bleibt weiterhin möglich.
        Beispiel: input_boolean.akku_entladung_sperren
      selector:
        entity:
          domain: input_boolean

    target_soc_number:
      name: Ziel-Ladestand
      description: z. B. input_number.akku_ziel_ladestand
      selector:
        entity:
          domain: input_number

    price_threshold_number:
      name: Lade-Preisgrenze Helfer
      description: >
        input_number-Helfer für die Lade-Preisgrenze in €/kWh.
        Beispiel: 0,16 entspricht 16 ct/kWh.
      selector:
        entity:
          domain: input_number

    price_sensor:
      name: Strompreis Sensor
      description: >
        Sensor für den aktuellen Strompreis.
        Der State des Sensors muss den Preis in €/kWh liefern.
        Beispiel: 0,16 oder 0.16 entspricht 16 ct/kWh.
      selector:
        entity:
          domain: sensor

    allow_price_charge_while_wallbox:
      name: Preisladen auch während Wallbox-Ladung erlauben
      description: >
        Aus = Wallbox hat Priorität, Hausakku entlädt nicht und lädt auch nicht.
        An = Hausakku darf bei günstigem Preis auch während Wallbox-Ladung laden.
      default: false
      selector:
        boolean: {}

    charge_power:
      name: Ladeleistung
      description: >
        Negativer Wert lädt den Akku. Für MS-A2 typischerweise -800.
      default: -800
      selector:
        number:
          min: -3000
          max: 0
          step: 10
          mode: box
          unit_of_measurement: W

    neutral_power:
      name: Neutralleistung
      description: Normalerweise 0 W.
      default: 0
      selector:
        number:
          min: -3000
          max: 3000
          step: 10
          mode: box
          unit_of_measurement: W

    discharge_price_offset:
      name: Entladen erst ab Preisaufschlag
      description: >
        Aufschlag auf die Lade-Preisgrenze, ab dem der Akku wieder entladen darf.
        Angabe in €/kWh. Der Mindestwert ist 0,10 €/kWh, also 10 ct/kWh.
        Beispiel: Bei Lade-Preisgrenze 0,16 €/kWh und Aufschlag 0,10 €/kWh
        darf der Akku erst ab 0,26 €/kWh wieder entladen.
      default: 0.10
      selector:
        number:
          min: 0.10
          max: 1
          step: 0.001
          mode: box
          unit_of_measurement: "€/kWh"

    wallbox_charging_state:
      name: Wallbox Status für "lädt"
      description: Bei Easee normalerweise charging.
      default: charging
      selector:
        text: {}

    control_mode_option:
      name: Batterie Steuerungsmodus
      description: Bei MS-A2 normalerweise mqtt_ctrl.
      default: mqtt_ctrl
      selector:
        text: {}

    normal_mode_option:
      name: Batterie Normalmodus
      description: Bei MS-A2 normalerweise general.
      default: general
      selector:
        text: {}

trigger:
  - platform: state
    entity_id: !input wallbox_status_sensor
    id: wallbox_changed

  - platform: state
    entity_id: !input force_charge_switch
    id: force_charge_changed

  - platform: state
    entity_id: !input price_charging_switch
    id: price_charging_switch_changed

  - platform: state
    entity_id: !input discharge_block_switch
    id: discharge_block_changed

  - platform: state
    entity_id: !input target_soc_number
    id: target_soc_changed

  - platform: state
    entity_id: !input price_threshold_number
    id: price_threshold_changed

  - platform: state
    entity_id: !input battery_soc_sensor
    id: soc_changed

  - platform: state
    entity_id: !input price_sensor
    id: price_changed

  - platform: time_pattern
    seconds: "/30"
    id: repeat_send

condition: []

action:
  - variables:
      battery_soc_sensor_var: !input battery_soc_sensor
      target_soc_number_var: !input target_soc_number
      price_threshold_number_var: !input price_threshold_number
      price_sensor_var: !input price_sensor
      wallbox_status_sensor_var: !input wallbox_status_sensor
      force_charge_switch_var: !input force_charge_switch
      price_charging_switch_var: !input price_charging_switch
      discharge_block_switch_var: !input discharge_block_switch

      allow_price_charge_while_wallbox_var: !input allow_price_charge_while_wallbox
      charge_power_var: !input charge_power
      neutral_power_var: !input neutral_power
      discharge_price_offset_var: !input discharge_price_offset
      wallbox_charging_state_var: !input wallbox_charging_state
      control_mode_option_var: !input control_mode_option
      normal_mode_option_var: !input normal_mode_option

      soc: >
        {{ (states(battery_soc_sensor_var) | string | replace(',', '.')) | float(999) }}

      target_soc: >
        {{ (states(target_soc_number_var) | string | replace(',', '.')) | float(0) }}

      price: >
        {{ (states(price_sensor_var) | string | replace(',', '.')) | float(999) }}

      price_threshold: >
        {{ (states(price_threshold_number_var) | string | replace(',', '.')) | float(0.16) }}

      discharge_price_offset_value: >
        {{ discharge_price_offset_var | float(0.10) }}

      discharge_price_limit: >
        {{
          ((states(price_threshold_number_var) | string | replace(',', '.')) | float(0.16))
          + (discharge_price_offset_var | float(0.10))
        }}

      wallbox_charging: >
        {{ is_state(wallbox_status_sensor_var, wallbox_charging_state_var) }}

      force_charge_on: >
        {{ is_state(force_charge_switch_var, 'on') }}

      price_charging_enabled: >
        {{ is_state(price_charging_switch_var, 'on') }}

      discharge_blocked: >
        {{ is_state(discharge_block_switch_var, 'on') }}

      soc_valid: >
        {{ states(battery_soc_sensor_var) not in ['unknown', 'unavailable', 'none', 'None', ''] }}

      target_soc_valid: >
        {{ states(target_soc_number_var) not in ['unknown', 'unavailable', 'none', 'None', ''] }}

      price_valid: >
        {{ states(price_sensor_var) not in ['unknown', 'unavailable', 'none', 'None', ''] }}

      price_threshold_valid: >
        {{ states(price_threshold_number_var) not in ['unknown', 'unavailable', 'none', 'None', ''] }}

      manual_charge_active: >
        {{
          force_charge_on | bool(false)
          and soc_valid | bool(false)
          and target_soc_valid | bool(false)
          and (soc | float(999)) < (target_soc | float(0))
        }}

      manual_target_reached: >
        {{
          force_charge_on | bool(false)
          and soc_valid | bool(false)
          and target_soc_valid | bool(false)
          and (soc | float(999)) >= (target_soc | float(0))
        }}

      price_charge_active: >
        {{
          price_charging_enabled | bool(false)
          and price_valid | bool(false)
          and price_threshold_valid | bool(false)
          and soc_valid | bool(false)
          and target_soc_valid | bool(false)
          and (price | float(999)) < (price_threshold | float(0.16))
          and (soc | float(999)) < (target_soc | float(0))
          and (
            allow_price_charge_while_wallbox_var | bool(false)
            or not (wallbox_charging | bool(false))
          )
        }}

      price_expensive_for_discharge: >
        {{
          price_valid | bool(false)
          and price_threshold_valid | bool(false)
          and (price | float(999)) >= (discharge_price_limit | float(999))
        }}

      discharge_allowed: >
        {{
          not (wallbox_charging | bool(false))
          and not (discharge_blocked | bool(false))
          and price_expensive_for_discharge | bool(false)
        }}

  - choose:
      - alias: Sofortladen aktiv - Akku bis Ziel-SOC laden
        conditions:
          - condition: template
            value_template: "{{ manual_charge_active | bool(false) }}"
        sequence:
          - service: select.select_option
            target:
              entity_id: !input battery_mode_select
            data:
              option: "{{ control_mode_option_var }}"

          - service: number.set_value
            target:
              entity_id: !input battery_power_number
            data:
              value: "{{ charge_power_var | float(0) }}"

      - alias: Automatisches Preisladen aktiv - Preis unter Grenze
        conditions:
          - condition: template
            value_template: "{{ price_charge_active | bool(false) }}"
        sequence:
          - service: select.select_option
            target:
              entity_id: !input battery_mode_select
            data:
              option: "{{ control_mode_option_var }}"

          - service: number.set_value
            target:
              entity_id: !input battery_power_number
            data:
              value: "{{ charge_power_var | float(0) }}"

      - alias: Wallbox lädt - Akku-Entladung stoppen
        conditions:
          - condition: template
            value_template: "{{ wallbox_charging | bool(false) }}"
        sequence:
          - service: select.select_option
            target:
              entity_id: !input battery_mode_select
            data:
              option: "{{ control_mode_option_var }}"

          - service: number.set_value
            target:
              entity_id: !input battery_power_number
            data:
              value: "{{ neutral_power_var | float(0) }}"

      - alias: Entladung gesperrt oder Strompreis nicht teuer genug - Akku neutral halten
        conditions:
          - condition: template
            value_template: >
              {{
                discharge_blocked | bool(false)
                or not (price_expensive_for_discharge | bool(false))
              }}
        sequence:
          - service: select.select_option
            target:
              entity_id: !input battery_mode_select
            data:
              option: "{{ control_mode_option_var }}"

          - service: number.set_value
            target:
              entity_id: !input battery_power_number
            data:
              value: "{{ neutral_power_var | float(0) }}"

    default:
      - alias: Strompreis teuer genug - Entladung freigeben
        service: number.set_value
        target:
          entity_id: !input battery_power_number
        data:
          value: "{{ neutral_power_var | float(0) }}"

      - service: select.select_option
        target:
          entity_id: !input battery_mode_select
        data:
          option: "{{ normal_mode_option_var }}"

  - if:
      - condition: template
        value_template: "{{ manual_target_reached | bool(false) }}"
    then:
      - service: input_boolean.turn_off
        target:
          entity_id: !input force_charge_switch

mode: restart
max_exceeded: silent
